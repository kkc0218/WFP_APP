<Window x:Class="WfpControlApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:WfpControlApp.Converters"
        Title="WFP Network Security Controller v8.0" Height="860" Width="1380"
        WindowStartupLocation="CenterScreen" Background="#0D1117"
        FontFamily="Segoe UI" Foreground="#C9D1D9">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
        <conv:InverseBoolConverter x:Key="InvBool"/>
        <conv:BoolToOnOffConverter x:Key="BoolOnOff"/>
        <conv:BoolToBrushConverter x:Key="BoolBrush"/>
        <conv:TabEqualsConverter x:Key="TabVis"/>
        <conv:TabEqualsBoolConverter x:Key="TabBool"/>
        <conv:ActionToBrushConverter x:Key="ActionBrush"/>
        <conv:BytesToDisplayConverter x:Key="BytesDisp"/>

        <!-- 공통 색상 -->
        <SolidColorBrush x:Key="PanelBg" Color="#161B22"/>
        <SolidColorBrush x:Key="SidebarBg" Color="#0D1117"/>
        <SolidColorBrush x:Key="CardBg" Color="#21262D"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#58A6FF"/>
        <SolidColorBrush x:Key="AccentRed" Color="#F85149"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#3FB950"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#D29922"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#BC8CFF"/>
        <SolidColorBrush x:Key="BorderCol" Color="#30363D"/>
        <SolidColorBrush x:Key="TextDim" Color="#8B949E"/>
        <SolidColorBrush x:Key="TextBright" Color="#F0F6FC"/>

        <!-- 버튼 스타일 -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#30363D"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A1F2E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#1F6FEB"/>
            <Setter Property="BorderBrush" Value="#388BFD"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#8B1A1A"/>
            <Setter Property="BorderBrush" Value="#F85149"/>
            <Setter Property="Foreground" Value="#FFCCCC"/>
        </Style>

        <Style x:Key="PurpleBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#5B21B6"/>
            <Setter Property="BorderBrush" Value="#BC8CFF"/>
            <Setter Property="Foreground" Value="#E9D5FF"/>
        </Style>

        <!-- 텍스트박스 -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="CaretBrush" Value="#58A6FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 사이드바 버튼 -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5" Margin="4,1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#F0F6FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid 스타일 -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#21262D"/>
            <Setter Property="RowBackground" Value="#161B22"/>
            <Setter Property="AlternatingRowBackground" Value="#1C2128"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#21262D"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1F6FEB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================================ -->
        <!-- 사이드바 -->
        <!-- ============================================================ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}" BorderBrush="#21262D" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="14,16,14,20">
                    <TextBlock Text="◆ WFP Security" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBlue}"/>
                    <TextBlock Text="Network Filter v8.0" FontSize="10.5" Foreground="{StaticResource TextDim}" Margin="0,3,0,0"/>
                    <Border CornerRadius="4" Padding="8,4" Margin="0,12,0,0"
                            Background="{Binding IsConnected, Converter={StaticResource BoolBrush}}" Opacity="0.15">
                        <TextBlock Text="{Binding StatusMessage}" FontSize="10.5" Foreground="{StaticResource TextBright}" HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,12">
                    <Button Content="▶ 드라이버 연결" Style="{StaticResource PrimaryBtn}" Command="{Binding ConnectCommand}"
                            Visibility="{Binding IsConnected, Converter={StaticResource InvBoolVis}}" Margin="0,2"/>
                    <Button Content="■ 연결 해제" Style="{StaticResource DangerBtn}" Command="{Binding DisconnectCommand}"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolVis}}" Margin="0,2"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4,0">
                        <TextBlock Text="모니터링" FontSize="10" Foreground="#484F58" FontWeight="SemiBold" Margin="14,0,0,4"/>
                        <Button Content="📊 대시보드" Style="{StaticResource NavBtn}" Command="{Binding NavigateCommand}" CommandParameter="Dashboard"/>
                        <Button Content="📡 패킷 캡처" Style="{StaticResource NavBtn}" Command="{Binding NavigateCommand}" CommandParameter="Capture"/>

                        <TextBlock Text="차단 정책" FontSize="10" Foreground="#484F58" FontWeight="SemiBold" Margin="14,14,0,4"/>
                        <Button Content="🔒 PID 차단" Style="{StaticResource NavBtn}" Command="{Binding NavigateCommand}" CommandParameter="PidBlock"/>
                        <Button Content="🧱 자가 보호" Style="{StaticResource NavBtn}" Command="{Binding NavigateCommand}" CommandParameter="SelfProtect"/>
                        <Button Content="🌐 SNI/QUIC/DNS" Style="{StaticResource NavBtn}" Command="{Binding NavigateCommand}" CommandParameter="SniBlock"/>
                        <Button Content="🧭 DNS 싱크홀" Style="{StaticResource NavBtn}" Command="{Binding NavigateCommand}" CommandParameter="DnsSinkhole"/>

                        <TextBlock Text="데이터 유출 방지" FontSize="10" Foreground="#484F58" FontWeight="SemiBold" Margin="14,14,0,4"/>
                        <Button Content="📤 업로드 DLP" Style="{StaticResource NavBtn}" Command="{Binding NavigateCommand}" CommandParameter="UploadDlp"/>
                        <Button Content="📱 앱 관리" Style="{StaticResource NavBtn}" Command="{Binding NavigateCommand}" CommandParameter="AppManage"/>

                        <TextBlock Text="시스템" FontSize="10" Foreground="#484F58" FontWeight="SemiBold" Margin="14,14,0,4"/>
                        <Button Content="📋 이벤트 로그" Style="{StaticResource NavBtn}" Command="{Binding NavigateCommand}" CommandParameter="EventLog"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- 메인 콘텐츠 -->
        <!-- ============================================================ -->
        <Border Grid.Column="1" Background="#0D1117">
            <Grid Margin="20,16">
                <!-- ============ 대시보드 ============ -->
                <StackPanel Visibility="{Binding SelectedTab, Converter={StaticResource TabVis}, ConverterParameter=Dashboard}">
                    <TextBlock Text="대시보드" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBright}" Margin="0,0,0,16"/>

                    <!-- 통계 카드 4개 -->
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,16">
                        <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16,14" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="캡처 패킷" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                <TextBlock Text="{Binding TotalCaptured}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16,14" Margin="3,0">
                            <StackPanel>
                                <TextBlock Text="PID 차단" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                <TextBlock Text="{Binding TotalBlocked}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentRed}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16,14" Margin="3,0">
                            <StackPanel>
                                <TextBlock Text="SNI/QUIC 차단" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                <TextBlock Text="{Binding SniBlocked}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentYellow}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16,14" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="업로드 차단" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                <TextBlock Text="{Binding UploadBlocked}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentPurple}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- 상태 패널 -->
                    <UniformGrid Rows="1" Columns="2" Margin="0,0,0,16">
                        <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16,14" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="기능 상태" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBright}" Margin="0,0,0,12"/>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="패킷 캡처" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding IsCapturing, Converter={StaticResource BoolOnOff}}" Foreground="{Binding IsCapturing, Converter={StaticResource BoolBrush}}" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="SNI/QUIC/DNS 차단" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SniBlockingEnabled, Converter={StaticResource BoolOnOff}}" Foreground="{Binding SniBlockingEnabled, Converter={StaticResource BoolBrush}}" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="DNS 싱크홀" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DnsSinkholeEnabled, Converter={StaticResource BoolOnOff}}" Foreground="{Binding DnsSinkholeEnabled, Converter={StaticResource BoolBrush}}" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="업로드 DLP" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding UploadBlockingEnabled, Converter={StaticResource BoolOnOff}}" Foreground="{Binding UploadBlockingEnabled, Converter={StaticResource BoolBrush}}" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="자가 보호" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelfProtectionEnabled, Converter={StaticResource BoolOnOff}}" Foreground="{Binding SelfProtectionEnabled, Converter={StaticResource BoolBrush}}" FontWeight="Bold"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16,14" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Flow Context" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBright}" Margin="0,0,0,12"/>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="활성 Flow Context" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ActiveFlows}" Foreground="{StaticResource AccentBlue}" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="모니터링 앱" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding MonitoredAppsCount}" Foreground="{StaticResource AccentBlue}" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="차단 PID" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding BlockedPid}" Foreground="{StaticResource AccentRed}" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="자가 보호 PID" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelfProtectionPid}" Foreground="{StaticResource AccentGreen}" FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="차단된 OpenProcess" Foreground="{StaticResource TextDim}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelfProtectionBlockedOpens}" Foreground="{StaticResource AccentYellow}" FontWeight="Bold"/>
                                </Grid>
                                <Button Content="상태 새로고침" Style="{StaticResource ActionBtn}" Command="{Binding RefreshStatusCommand}" HorizontalAlignment="Right" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- 최근 이벤트 -->
                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="최근 이벤트" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBright}" Margin="0,0,0,8"/>
                            <ListBox ItemsSource="{Binding EventLog}" Background="Transparent" BorderThickness="0"
                                     Foreground="#8B949E" FontSize="11" FontFamily="Consolas" MaxHeight="150"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="4,2"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ============ 패킷 캡처 ============ -->
                <StackPanel Visibility="{Binding SelectedTab, Converter={StaticResource TabVis}, ConverterParameter=Capture}">
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="패킷 캡처" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBright}" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{Binding IsCapturing, Converter={StaticResource BoolOnOff}, StringFormat='캡처 {0}'}" Style="{StaticResource PrimaryBtn}" Command="{Binding ToggleCaptureCommand}" Margin="0,0,6,0"/>
                            <Button Content="큐 초기화" Style="{StaticResource ActionBtn}" Command="{Binding ClearQueueCommand}" Margin="0,0,6,0"/>
                            <Button Content="로그 클리어" Style="{StaticResource ActionBtn}" Command="{Binding ClearPacketLogCommand}"/>
                        </StackPanel>
                    </DockPanel>
                    <DataGrid ItemsSource="{Binding PacketLog}" MaxHeight="580">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="시간" Binding="{Binding Timestamp}" Width="160"/>
                            <DataGridTemplateColumn Header="액션" Width="65">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Action}" Foreground="{Binding Action, Converter={StaticResource ActionBrush}}" FontWeight="Bold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="방향" Binding="{Binding Direction}" Width="45"/>
                            <DataGridTextColumn Header="프로토콜" Binding="{Binding Protocol}" Width="60"/>
                            <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="65"/>
                            <DataGridTextColumn Header="로컬" Binding="{Binding LocalAddress}" Width="120"/>
                            <DataGridTextColumn Header="L.Port" Binding="{Binding LocalPort}" Width="55"/>
                            <DataGridTextColumn Header="리모트" Binding="{Binding RemoteAddress}" Width="120"/>
                            <DataGridTextColumn Header="R.Port" Binding="{Binding RemotePort}" Width="55"/>
                            <DataGridTextColumn Header="크기" Binding="{Binding PacketSize}" Width="65"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

                <!-- ============ PID 차단 ============ -->
                <StackPanel Visibility="{Binding SelectedTab, Converter={StaticResource TabVis}, ConverterParameter=PidBlock}">
                    <TextBlock Text="PID 기반 프로세스 차단" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBright}" Margin="0,0,0,16"/>
                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="20">
                        <StackPanel>
                            <TextBlock Text="특정 프로세스(PID)의 모든 아웃바운드 연결을 차단합니다." Foreground="{StaticResource TextDim}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="현재 차단 PID:" FontSize="14" Foreground="{StaticResource TextDim}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding BlockedPid}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentRed}" VerticalAlignment="Center"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding PidInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}" Width="200" Margin="0,0,8,0"/>
                                <Button Content="차단 설정" Style="{StaticResource PrimaryBtn}" Command="{Binding SetBlockPidCommand}" Margin="0,0,8,0"/>
                                <Button Content="차단 해제" Style="{StaticResource DangerBtn}" Command="{Binding ResetBlockPidCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ============ 자가 보호 ============ -->
                <StackPanel Visibility="{Binding SelectedTab, Converter={StaticResource TabVis}, ConverterParameter=SelfProtect}">
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="드라이버 / 유저모드 에이전트 자가 보호" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBright}" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{Binding SelfProtectionEnabled, Converter={StaticResource BoolOnOff}, StringFormat='자가 보호 {0}'}"
                                    Style="{StaticResource PrimaryBtn}" Command="{Binding ToggleSelfProtectionCommand}" Margin="0,0,6,0"/>
                            <Button Content="상태 새로고침" Style="{StaticResource ActionBtn}" Command="{Binding RefreshSelfProtectionCommand}" Margin="0,0,6,0"/>
                            <Button Content="앱 종료" Style="{StaticResource ActionBtn}" Command="{Binding ExitApplicationCommand}" ToolTip="보호 해제 후 프로그램 종료"/>
                        </StackPanel>
                    </DockPanel>

                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="현재 WPF 에이전트 프로세스를 커널 콜백으로 보호합니다." FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBright}" Margin="0,0,0,8"/>
                            <TextBlock Text="외부 프로세스가 OpenProcess로 메모리에 접근하거나 PROCESS_TERMINATE 권한으로 강제 종료를 시도하면, 드라이버가 해당 위험 권한을 제거합니다. 에이전트가 종료되면 커널이 보호 PID를 자동으로 정리합니다."
                                       Foreground="{StaticResource TextDim}" TextWrapping="Wrap" Margin="0,0,0,14"/>

                            <Border Background="#162037" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="보호 옵션 (권장)" Foreground="{StaticResource AccentBlue}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <CheckBox Content="강제 종료 차단 (PROCESS_TERMINATE)"
                                              IsChecked="{Binding SelfProtectBlockTerminate}" Foreground="{StaticResource TextBright}" Margin="0,0,0,6"/>
                                    <CheckBox Content="OpenProcess 메모리/핸들 권한 차단 (VM_READ/WRITE/OPERATION, DUP_HANDLE 등)"
                                              IsChecked="{Binding SelfProtectBlockMemoryAccess}" Foreground="{StaticResource TextBright}"/>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="현재 앱 PID" Foreground="{StaticResource TextDim}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Column="1" Text="{Binding AgentProcessId}" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="1" Text="보호 대상 PID" Foreground="{StaticResource TextDim}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelfProtectionPid}" Foreground="{StaticResource AccentGreen}" FontWeight="Bold" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="2" Text="콜백 등록 상태" Foreground="{StaticResource TextDim}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelfProtectionReady, Converter={StaticResource BoolOnOff}}" Foreground="{Binding SelfProtectionReady, Converter={StaticResource BoolBrush}}" FontWeight="Bold" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="3" Text="보호 상태" Foreground="{StaticResource TextDim}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelfProtectionEnabled, Converter={StaticResource BoolOnOff}}" Foreground="{Binding SelfProtectionEnabled, Converter={StaticResource BoolBrush}}" FontWeight="Bold" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="4" Text="적용 플래그" Foreground="{StaticResource TextDim}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelfProtectionFlagsHex}" Foreground="{StaticResource AccentYellow}" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <UniformGrid Rows="1" Columns="2">
                        <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16,14" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="차단된 OpenProcess / Duplicate" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                <TextBlock Text="{Binding SelfProtectionBlockedOpens}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentYellow}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16,14" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="차단된 종료 시도" FontSize="11" Foreground="{StaticResource TextDim}"/>
                                <TextBlock Text="{Binding SelfProtectionBlockedTerminates}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentRed}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>

                <!-- ============ SNI/QUIC/DNS 차단 ============ -->
                <StackPanel Visibility="{Binding SelectedTab, Converter={StaticResource TabVis}, ConverterParameter=SniBlock}">
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="SNI / QUIC / DNS URL 차단" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBright}" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{Binding SniBlockingEnabled, Converter={StaticResource BoolOnOff}, StringFormat='차단 {0}'}" Style="{StaticResource PrimaryBtn}" Command="{Binding ToggleSniBlockingCommand}" Margin="0,0,6,0"/>
                            <Button Content="전체 초기화" Style="{StaticResource DangerBtn}" Command="{Binding ClearSniListCommand}"/>
                        </StackPanel>
                    </DockPanel>
                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding SniUrlInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}" Width="360" Margin="0,0,8,0"/>
                            <Button Content="URL 차단/해제 (토글)" Style="{StaticResource PrimaryBtn}" Command="{Binding ToggleSniUrlCommand}" Margin="0,0,8,0"/>
                            <Button Content="새로고침" Style="{StaticResource ActionBtn}" Command="{Binding RefreshSniListCommand}"/>
                        </StackPanel>
                    </Border>
                    <DataGrid ItemsSource="{Binding SniBlockList}" MaxHeight="420">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                            <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*"/>
                            <DataGridTextColumn Header="차단 횟수" Binding="{Binding BlockCount}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

                <!-- ============ DNS 싱크홀 ============ -->
                <StackPanel Visibility="{Binding SelectedTab, Converter={StaticResource TabVis}, ConverterParameter=DnsSinkhole}">
                    <TextBlock Text="DNS 싱크홀" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBright}" Margin="0,0,0,16"/>
                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="20">
                        <StackPanel>
                            <TextBlock Text="차단 URL에 대한 DNS 응답을 싱크홀 IP로 수정합니다." Foreground="{StaticResource TextDim}" Margin="0,0,0,16"/>
                            <Button Content="{Binding DnsSinkholeEnabled, Converter={StaticResource BoolOnOff}, StringFormat='싱크홀 {0}'}"
                                    Style="{StaticResource PrimaryBtn}" Command="{Binding ToggleDnsSinkholeCommand}" HorizontalAlignment="Left" Margin="0,0,0,16"/>
                            <TextBlock Text="싱크홀 IP 설정:" Foreground="{StaticResource TextDim}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding SinkholeIpInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}" Width="200" Margin="0,0,8,0"/>
                                <Button Content="IP 설정" Style="{StaticResource PrimaryBtn}" Command="{Binding SetSinkholeIpCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ============ 업로드 DLP ============ -->
                <StackPanel Visibility="{Binding SelectedTab, Converter={StaticResource TabVis}, ConverterParameter=UploadDlp}">
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="애플리케이션 기반 업로드 DLP" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBright}" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{Binding UploadBlockingEnabled, Converter={StaticResource BoolOnOff}, StringFormat='차단 {0}'}"
                                    Style="{StaticResource PrimaryBtn}" Command="{Binding ToggleUploadBlockingCommand}" Margin="0,0,6,0"/>
                        </StackPanel>
                    </DockPanel>
                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="DLP 상태" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextBright}" Margin="0,0,0,8"/>
                            <WrapPanel>
                                <TextBlock Foreground="{StaticResource TextDim}" Margin="0,0,20,4"><Run Text="활성 플로우: "/><Run Text="{Binding ActiveFlows}" Foreground="{StaticResource AccentBlue}"/></TextBlock>
                                <TextBlock Foreground="{StaticResource TextDim}" Margin="0,0,20,4"><Run Text="모니터링 앱: "/><Run Text="{Binding MonitoredAppsCount}" Foreground="{StaticResource AccentBlue}"/></TextBlock>
                                <TextBlock Foreground="{StaticResource TextDim}" Margin="0,0,20,4"><Run Text="차단된 업로드: "/><Run Text="{Binding UploadBlocked}" Foreground="{StaticResource AccentRed}"/></TextBlock>
                                <TextBlock Foreground="{StaticResource TextDim}" Margin="0,0,20,4"><Run Text="임계값: "/><Run Text="{Binding ThresholdBytes, Converter={StaticResource BytesDisp}}" Foreground="{StaticResource AccentYellow}"/></TextBlock>
                                <TextBlock Foreground="{StaticResource TextDim}" Margin="0,0,20,4"><Run Text="윈도우: "/><Run Text="{Binding WindowSeconds}" Foreground="{StaticResource AccentYellow}"/><Run Text="초"/></TextBlock>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="임계값(KB):" Foreground="{StaticResource TextDim}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding ThresholdInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}" Width="80" Margin="0,0,12,0"/>
                            <TextBlock Text="윈도우(초):" Foreground="{StaticResource TextDim}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding WindowInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}" Width="60" Margin="0,0,12,0"/>
                            <Button Content="설정" Style="{StaticResource PrimaryBtn}" Command="{Binding SetThresholdCommand}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16" Margin="0,0,0,10">
                        <TextBlock Foreground="{StaticResource TextDim}" TextWrapping="Wrap" FontSize="12"
                                   Text="모니터링 대상 앱의 모든 아웃바운드 트래픽을 Flow Context 기반으로 추적합니다. 앱별 임계값 초과 시 해당 플로우를 차단합니다. 앱 관리 탭에서 대상 앱을 등록하세요."/>
                    </Border>
                    <DataGrid ItemsSource="{Binding MonitoredAppList}" MaxHeight="260" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                            <DataGridTextColumn Header="앱 이름" Binding="{Binding AppName}" Width="*"/>
                            <DataGridTextColumn Header="활성 플로우" Binding="{Binding ActiveFlows}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

                <!-- ============ 앱 관리 ============ -->
                <StackPanel Visibility="{Binding SelectedTab, Converter={StaticResource TabVis}, ConverterParameter=AppManage}">
                    <TextBlock Text="모니터링 대상 앱 관리" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBright}" Margin="0,0,0,16"/>
                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="앱 프리셋 등록" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextBright}" Margin="0,0,0,8"/>
                            <WrapPanel>
                                <Button Content="브라우저" Style="{StaticResource ActionBtn}" Command="{Binding AddAppPresetCommand}" CommandParameter="0" Margin="0,0,6,4"/>
                                <Button Content="메신저" Style="{StaticResource ActionBtn}" Command="{Binding AddAppPresetCommand}" CommandParameter="1" Margin="0,0,6,4"/>
                                <Button Content="전체" Style="{StaticResource PrimaryBtn}" Command="{Binding AddAppPresetCommand}" CommandParameter="99" Margin="0,0,6,4"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding AppNameInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}" Width="250" Margin="0,0,8,0"/>
                            <Button Content="앱 추가" Style="{StaticResource PrimaryBtn}" Command="{Binding AddMonitoredAppCommand}" Margin="0,0,8,0"/>
                            <Button Content="새로고침" Style="{StaticResource ActionBtn}" Command="{Binding RefreshAppListCommand}" Margin="0,0,8,0"/>
                            <Button Content="전체 초기화" Style="{StaticResource DangerBtn}" Command="{Binding ClearAppListCommand}"/>
                        </StackPanel>
                    </Border>
                    <DataGrid ItemsSource="{Binding MonitoredAppList}" MaxHeight="380">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                            <DataGridTextColumn Header="앱 이름" Binding="{Binding AppName}" Width="*"/>
                            <DataGridTextColumn Header="활성 플로우" Binding="{Binding ActiveFlows}" Width="100"/>
                            <DataGridTemplateColumn Header="" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="제거" Style="{StaticResource DangerBtn}" Padding="8,3"
                                                Command="{Binding DataContext.RemoveMonitoredAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding AppName}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

                <!-- ============ 이벤트 로그 ============ -->
                <StackPanel Visibility="{Binding SelectedTab, Converter={StaticResource TabVis}, ConverterParameter=EventLog}">
                    <TextBlock Text="이벤트 로그" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBright}" Margin="0,0,0,16"/>
                    <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="12">
                        <ListBox ItemsSource="{Binding EventLog}" Background="Transparent" BorderThickness="0"
                                 Foreground="#8B949E" FontSize="11.5" FontFamily="Consolas" MaxHeight="550">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="6,3"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
